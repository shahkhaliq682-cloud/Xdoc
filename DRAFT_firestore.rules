rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'userRole']) &&
             data.uid is string && data.fullName is string && data.userRole is string;
    }

    function isValidHospital(data) {
      return data.hospitalName is string && data.hospitalName.size() <= 200 &&
             data.status in ['active', 'inactive'];
    }

    function isValidToken(data) {
      return data.patientName is string && data.hospitalId is string &&
             data.status in ['Waiting', 'In Progress', 'Completed', 'Cancelled'] &&
             data.tokenNumber is string;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isOwner(userId) || existing().userRole == 'hospital');
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().userRole == existing().userRole;
    }

    // 2. Hospitals Collection
    match /hospitals/{hospitalId} {
      allow get: if true;
      allow list: if true; // Public listing
      allow create: if isOwner(hospitalId) && isValidHospital(incoming());
      allow update: if isOwner(hospitalId) && isValidHospital(incoming());

      // Doctors Subcollection
      match /doctors/{doctorId} {
        allow read: if true;
        allow write: if isOwner(hospitalId);
      }

      // Staff Subcollection
      match /staff/{staffId} {
        allow read: if isOwner(hospitalId);
        allow write: if isOwner(hospitalId);
      }
    }

    // 3. Tokens Collection
    match /tokens/{tokenId} {
      allow read: if isSignedIn() && (
        incoming().hospitalId == request.auth.uid || // Hospital side
        existing().hospitalId == request.auth.uid || 
        incoming().patientId == request.auth.uid || // Patient side (if we add patientId later)
        existing().patientId == request.auth.uid
      );
      allow list: if isSignedIn(); // Filtered by hospitalId on client
      allow create: if isSignedIn() && isValidToken(incoming());
      allow update: if isSignedIn() && (
        // Hospital update status
        (incoming().hospitalId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Owner update (cancel)
        (existing().patientId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isSignedIn() && (existing().hospitalId == request.auth.uid);
    }
  }
}
