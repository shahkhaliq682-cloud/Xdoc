rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shahkhaliq682@gmail.com' && request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Users can see each other's basic profiles (maybe restrict in production)
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['Patient', 'Admin', 'SuperAdmin'];
    }

    // --- Hospital Rules ---
    match /hospitals/{hospitalId} {
      allow read: if true; // Public listings
      allow create: if isSignedIn(); // Anyone can submit for registration (needs manual approval later)
      allow update: if isSuperAdmin() || (isSignedIn() && isHospitalAdmin(hospitalId));
      allow delete: if isSuperAdmin();
    }

    function isHospitalAdmin(hospitalId) {
       // Logic to check if user is admin of this hospital
       // Actually user profile role could be 'Admin' and they have a 'hospitalId' field
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hospitalId == hospitalId;
    }

    // --- Token Rules ---
    match /tokens/{tokenId} {
      allow read: if true; // Public queue monitor
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && (isHospitalAdmin(incoming().hospitalId) || isSuperAdmin()));
      allow delete: if isSuperAdmin();
    }

  }
}
