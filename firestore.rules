rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Development Rules - Allow all access
    match /users/{userId} {
      allow read, write: if true;
    }
    match /hospitals/{hospitalId} {
      allow read, write: if true;
    }
    match /doctors/{doctorId} {
      allow read, write: if true;
    }
    match /tokens/{tokenId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
