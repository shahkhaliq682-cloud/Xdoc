rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid is string && (data.role is string || data.userRole is string);
    }

    function isValidHospital(data) {
      return data.hospitalName is string && data.hospitalName.size() <= 200 &&
             data.status in ['active', 'inactive'];
    }

    function isValidToken(data) {
      return data.patientName is string && data.hospitalId is string &&
             data.status in ['Waiting', 'In Progress', 'Completed', 'Cancelled'] &&
             data.tokenNumber is string;
    }

    // --- Match Blocks ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // 2. Hospitals Collection
    match /hospitals/{hospitalId} {
      // Patients can see active hospitals
      allow get: if true;
      allow list: if true; 
      
      // Admin hospital can manage their profile
      allow create: if isOwner(hospitalId) && isValidHospital(incoming());
      allow update: if isOwner(hospitalId) && isValidHospital(incoming());

      // Doctors Subcollection
      match /doctors/{doctorId} {
        allow read: if true;
        allow write: if isOwner(hospitalId);
      }

      // Staff Subcollection
      match /staff/{staffId} {
        allow read: if isOwner(hospitalId);
        allow write: if isOwner(hospitalId);
      }
    }

    // 3. Tokens Collection
    match /tokens/{tokenId} {
      // Both hospitals and patients need to see tokens
      // But only relevant ones. For now, allow list if hospitalId matches or patientId matches.
      allow read: if isSignedIn(); 
      allow list: if isSignedIn() && (
        resource.data.hospitalId == request.auth.uid || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn() && isValidToken(incoming());
      
      allow update: if isSignedIn() && (
        // Hospital update status or other fields
        isOwner(existing().hospitalId) ||
        // Patient update status (cancel)
        isOwner(existing().patientId)
      );
      
      allow delete: if isSignedIn() && isOwner(existing().hospitalId);
    }
  }
}
