rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // hospitals
    match /hospitals/{hospitalId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(hospitalId);

      match /doctors/{doctorId} { allow read: if true; allow write: if isOwner(hospitalId); }
      match /staff/{staffId} { allow read: if true; allow write: if isOwner(hospitalId); }
    }

    // users
    match /users/{userId} {
      allow get, list: if true;
      allow write: if isOwner(userId);
    }

    // tokens
    match /tokens/{tokenId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    
    // connection test
    match /test/connection {
      allow get: if true;
    }
  }
}
