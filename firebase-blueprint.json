{
  "entities": {
    "User": {
      "title": "User",
      "description": "Patient user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "userRole": { "type": "string", "enum": ["patient", "hospital", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "userRole"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Hospital profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "hospitalName": { "type": "string" },
        "hospitalType": { "type": "string" },
        "city": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "startingFee": { "type": "string" },
        "emergency247": { "type": "boolean" }
      },
      "required": ["uid", "hospitalName", "status"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile in hospital",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] }
      },
      "required": ["name", "specialization"]
    },
    "Token": {
      "title": "Token",
      "description": "Appointment/Wait token",
      "type": "object",
      "properties": {
        "hospitalId": { "type": "string" },
        "patientName": { "type": "string" },
        "tokenNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["Waiting", "In Progress", "Completed", "Cancelled"] }
      },
      "required": ["hospitalId", "patientName", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Patient profiles"
    },
    "/hospitals/{hospitalId}": {
      "schema": "Hospital",
      "description": "Hospital registry"
    },
    "/hospitals/{hospitalId}/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctors list for a hospital"
    },
    "/hospitals/{hospitalId}/staff/{staffId}": {
       "schema": "object",
       "description": "Staff list for a hospital"
    },
    "/tokens/{tokenId}": {
      "schema": "Token",
      "description": "Consultation tokens"
    }
  }
}
