{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "hospital_admin", "super_admin"] },
        "createdAt": { "type": "object" },
        "profile": { "type": "object" }
      },
      "required": ["uid", "email", "role"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Hospital profile data",
      "type": "object",
      "properties": {
        "hospitalName": { "type": "string" },
        "ownerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "area": { "type": "string" },
        "type": { "type": "string" },
        "specializations": { "type": "array" },
        "facilities": { "type": "array" },
        "openDays": { "type": "array" },
        "status": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["hospitalName", "uid"]
    },
    "Token": {
      "title": "Token",
      "description": "Medical appointment/queue token",
      "type": "object",
      "properties": {
        "hospitalId": { "type": "string" },
        "hospitalName": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "tokenNumber": { "type": "string" },
        "status": { "type": "string" },
        "fee": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["hospitalId", "tokenNumber"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "User submit message details via support desk",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "hospitals": {
      "schema": "Hospital",
      "description": "Collection of all registered hospitals"
    },
    "users": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "tokens": {
      "schema": "Token",
      "description": "Queue tokens for all hospitals"
    },
    "contact_messages": {
      "schema": "ContactMessage",
      "description": "User feedback and queries submitted from the public footer contact form"
    },
    "hospitals/{hospitalId}/doctors": {
      "schema": "object",
      "description": "Subcollection of doctors in a hospital"
    },
    "hospitals/{hospitalId}/staff": {
      "schema": "object",
      "description": "Subcollection of staff in a hospital"
    }
  }
}
