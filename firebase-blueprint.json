{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Patient", "Admin", "SuperAdmin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Hospital or Clinic facility data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "city": { "type": "string" },
        "area": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "specializations": { "type": "array", "items": { "type": "string" } },
        "facilities": { "type": "array", "items": { "type": "string" } },
        "insurancePanels": { "type": "array", "items": { "type": "string" } },
        "startingFee": { "type": "number" },
        "emergencyFee": { "type": "number" },
        "imageUrl": { "type": "string" },
        "verified": { "type": "boolean" },
        "isOpen": { "type": "boolean" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "emergencyContact": { "type": "string" },
        "about": { "type": "string" },
        "openingTime": { "type": "string" },
        "closingTime": { "type": "string" },
        "openDays": { "type": "array", "items": { "type": "string" } },
        "hasEmergency247": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "isSuspended": { "type": "boolean" }
      },
      "required": ["id", "name", "city", "area", "verified"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile and availability data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "qualifications": { "type": "array", "items": { "type": "string" } },
        "fee": { "type": "number" },
        "availableToday": { "type": "boolean" },
        "nextSlot": { "type": "string" },
        "imageUrl": { "type": "string" },
        "verified": { "type": "boolean" },
        "title": { "type": "string" }
      },
      "required": ["id", "hospitalId", "name", "specialization", "fee"]
    },
    "Token": {
      "title": "Token",
      "description": "Token for queue management",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "number": { "type": "string" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "doctorName": { "type": "string" },
        "timeSlot": { "type": "string" },
        "status": { "type": "string" },
        "isEmergency": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fee": { "type": "number" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "hospitalId", "number", "patientName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/hospitals/{hospitalId}": {
      "schema": "Hospital",
      "description": "Hospitals collection"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctors collection"
    },
    "/tokens/{tokenId}": {
      "schema": "Token",
      "description": "Queue tokens collection"
    }
  }
}
